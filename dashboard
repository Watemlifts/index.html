<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>🤖 Watemhost Trading Bot</title>
    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0b0e17;
            color: #e0e6ef;
            line-height: 1.6;
            padding: 20px;
        }
        .container {
            max-width: 1300px;
            margin: 0 auto;
        }

        /* ===== HEADER ===== */
        header {
            text-align: center;
            padding: 40px 20px 20px;
        }
        header h1 {
            font-size: 3rem;
            background: linear-gradient(135deg, #00d2ff, #3a7bd5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
        }
        header p {
            font-size: 1.2rem;
            color: #b0c4de;
            margin-top: 10px;
        }

        /* ===== FREE TRIAL BANNER ===== */
        .trial-banner {
            background: #1a2a4a;
            border-left: 6px solid #00d2ff;
            border-radius: 10px;
            padding: 18px 25px;
            margin: 30px auto;
            max-width: 800px;
            text-align: center;
            font-size: 1.1rem;
            box-shadow: 0 0 20px rgba(0, 210, 255, 0.15);
        }
        .trial-banner strong {
            color: #00d2ff;
        }

        /* ===== PLAN CARDS ===== */
        .plans {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            justify-content: center;
            margin: 40px 0;
        }
        .plan {
            background: #141b2b;
            border-radius: 16px;
            padding: 30px 25px;
            flex: 1 1 280px;
            max-width: 350px;
            border: 1px solid #2a3a5a;
            transition: transform 0.2s, border-color 0.2s;
            display: flex;
            flex-direction: column;
        }
        .plan:hover {
            transform: translateY(-6px);
            border-color: #3a7bd5;
        }
        .plan h2 {
            font-size: 1.8rem;
            color: #fff;
            margin-bottom: 6px;
        }
        .plan .price {
            font-size: 2.2rem;
            font-weight: 700;
            color: #00d2ff;
            margin: 12px 0 6px;
        }
        .plan .price small {
            font-size: 1rem;
            color: #b0c4de;
        }
        .plan .features {
            list-style: none;
            margin: 20px 0;
            flex-grow: 1;
        }
        .plan .features li {
            padding: 6px 0;
            border-bottom: 1px solid #1f2b3f;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .plan .features li::before {
            content: "✅";
            color: #2ecc71;
        }
        .plan .actions {
            display: flex;
            gap: 12px;
            margin-top: 15px;
            flex-wrap: wrap;
        }
        .btn {
            display: inline-block;
            background: #3a7bd5;
            color: #fff;
            padding: 12px 24px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: background 0.2s;
            font-size: 1rem;
            flex: 1;
            text-align: center;
        }
        .btn:hover {
            background: #2a5fa0;
        }
        .btn-outline {
            background: transparent;
            border: 2px solid #3a7bd5;
            color: #3a7bd5;
        }
        .btn-outline:hover {
            background: #3a7bd5;
            color: #fff;
        }
        .btn-demo {
            background: #1f2b3f;
            border: 1px solid #3a7bd5;
        }
        .btn-demo:hover {
            background: #2a3a5a;
        }

        /* ===== SUBSCRIPTION / LOGIN TABS ===== */
        .tab-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 20px;
        }
        .tab-btn {
            background: transparent;
            border: none;
            color: #b0c4de;
            font-size: 1.2rem;
            font-weight: 600;
            padding: 8px 20px;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: 0.2s;
        }
        .tab-btn.active {
            color: #00d2ff;
            border-bottom-color: #00d2ff;
        }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
        }

        /* ===== FORM SECTIONS ===== */
        .form-section {
            background: #141b2b;
            border-radius: 16px;
            padding: 40px 35px;
            margin: 30px 0;
            border: 1px solid #2a3a5a;
        }
        .form-section h2 {
            text-align: center;
            margin-bottom: 30px;
            font-size: 2rem;
        }
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }
        .form-grid .full-width {
            grid-column: 1 / -1;
        }
        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 6px;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 16px;
            background: #0b0e17;
            border: 1px solid #2a3a5a;
            border-radius: 8px;
            color: #e0e6ef;
            font-size: 1rem;
        }
        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #3a7bd5;
        }
        .submit-btn {
            background: #00d2ff;
            color: #0b0e17;
            font-weight: 700;
            padding: 16px;
            border: none;
            border-radius: 40px;
            font-size: 1.2rem;
            cursor: pointer;
            transition: background 0.2s;
            width: 100%;
            margin-top: 10px;
        }
        .submit-btn:hover {
            background: #3a7bd5;
            color: #fff;
        }
        .error-msg {
            color: #e74c3c;
            text-align: center;
            margin-top: 12px;
            display: none;
        }
        .success-msg {
            color: #2ecc71;
            text-align: center;
            margin-top: 12px;
            display: none;
        }
        .form-footer {
            text-align: center;
            margin-top: 15px;
            color: #b0c4de;
        }
        .form-footer a {
            color: #00d2ff;
            text-decoration: none;
        }

        /* ===== PAYMENT OPTIONS ===== */
        .payment-options {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            justify-content: center;
            margin: 30px 0 20px;
            padding: 20px;
            background: #0b0e17;
            border-radius: 12px;
            border: 1px solid #1f2b3f;
        }
        .payment-options .option {
            flex: 1 1 200px;
            text-align: center;
        }
        .payment-options .option h4 {
            color: #00d2ff;
            margin-bottom: 6px;
        }

        /* ===== MODAL (same as before) ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.75);
            align-items: center;
            justify-content: center;
            z-index: 999;
        }
        .modal-overlay.active {
            display: flex;
        }
        .modal {
            background: #141b2b;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            border-radius: 16px;
            padding: 30px 30px 20px;
            border: 1px solid #3a7bd5;
            position: relative;
        }
        .modal h2 {
            color: #fff;
            margin-bottom: 10px;
        }
        .modal .close-btn {
            position: absolute;
            top: 16px;
            right: 22px;
            font-size: 2rem;
            cursor: pointer;
            color: #b0c4de;
            transition: color 0.2s;
        }
        .modal .close-btn:hover {
            color: #fff;
        }
        .modal .demo-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 20px 0;
            background: #0b0e17;
            padding: 15px;
            border-radius: 10px;
        }
        .demo-stats .stat {
            text-align: center;
        }
        .demo-stats .stat .label {
            font-size: 0.85rem;
            color: #b0c4de;
        }
        .demo-stats .stat .value {
            font-size: 1.3rem;
            font-weight: 700;
        }
        .demo-stats .stat .value.green { color: #2ecc71; }
        .demo-stats .stat .value.red { color: #e74c3c; }
        .demo-signals {
            list-style: none;
            margin: 15px 0;
        }
        .demo-signals li {
            padding: 8px 0;
            border-bottom: 1px solid #1f2b3f;
            display: flex;
            justify-content: space-between;
        }
        .demo-signals .signal-change {
            font-weight: 600;
        }

        /* ===== FOOTER ===== */
        footer {
            text-align: center;
            padding: 30px 0 10px;
            color: #6a7a8f;
            font-size: 0.9rem;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 700px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
            .plans {
                flex-direction: column;
                align-items: center;
            }
            .plan {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
<div class="container">

    <!-- HEADER -->
    <header>
        <h1>🤖 Watemhost Trading Bot</h1>
        <p>Automated crypto trading &amp; DeFi signals – start your <strong>7‑day free trial</strong> today!</p>
    </header>

    <!-- FREE TRIAL BANNER -->
    <div class="trial-banner">
        🛡️ <strong>7‑day money‑back guarantee</strong> – if you’re not satisfied, cancel anytime.
    </div>

    <!-- PLAN CARDS -->
    <div class="plans">
        <!-- Basic -->
        <div class="plan">
            <h2>Basic</h2>
            <div class="price">1,000 <small>UGX / month</small></div>
            <ul class="features">
                <li>Daily trading signals</li>
                <li>Basic portfolio tracking</li>
                <li>Email alerts</li>
                <li>Web3 balance checks</li>
            </ul>
            <div class="actions">
                <a href="#subscribe-section" class="btn" onclick="selectPlan('basic')">Select</a>
                <button class="btn btn-demo" onclick="openDemo('basic')">🔍 Demo</button>
            </div>
        </div>

        <!-- Premium -->
        <div class="plan">
            <h2>Premium</h2>
            <div class="price">2,000 <small>UGX / month</small></div>
            <ul class="features">
                <li>Real-time trading signals</li>
                <li>Advanced portfolio tracking</li>
                <li>Telegram / Discord alerts</li>
                <li>Priority support</li>
                <li>Custom trading strategies</li>
            </ul>
            <div class="actions">
                <a href="#subscribe-section" class="btn" onclick="selectPlan('premium')">Select</a>
                <button class="btn btn-demo" onclick="openDemo('premium')">🔍 Demo</button>
            </div>
        </div>

        <!-- Enterprise -->
        <div class="plan">
            <h2>Enterprise</h2>
            <div class="price">3,000 <small>UGX / year</small></div>
            <ul class="features">
                <li>Everything in Premium</li>
                <li>White‑label solution</li>
                <li>Dedicated API access</li>
                <li>24/7 phone support</li>
                <li>Team accounts (up to 5)</li>
                <li>Custom integrations</li>
            </ul>
            <div class="actions">
                <a href="#subscribe-section" class="btn" onclick="selectPlan('enterprise')">Select</a>
                <button class="btn btn-demo" onclick="openDemo('enterprise')">🔍 Demo</button>
            </div>
        </div>
    </div>

    <!-- ===== SUBSCRIPTION / LOGIN TABS ===== -->
    <div id="subscribe-section">
        <div class="tab-container">
            <button class="tab-btn active" data-tab="signup-tab" onclick="switchTab('signup-tab')">📝 Sign Up</button>
            <button class="tab-btn" data-tab="login-tab" onclick="switchTab('login-tab')">🔐 Log In</button>
        </div>

        <!-- SIGNUP TAB -->
        <div id="signup-tab" class="tab-content active">
            <div class="form-section">
                <h2>📝 Start Your Free Trial</h2>
                <p style="text-align:center; margin-bottom:25px;">Fill in your details and choose your preferred plan.</p>
                <form id="signupForm">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="firstName">First Name *</label>
                            <input type="text" id="firstName" required />
                        </div>
                        <div class="form-group">
                            <label for="lastName">Last Name *</label>
                            <input type="text" id="lastName" required />
                        </div>
                        <div class="form-group">
                            <label for="email">Email Address *</label>
                            <input type="email" id="email" required />
                        </div>
                        <div class="form-group">
                            <label for="phone">Phone Number (for Mobile Money) *</label>
                            <input type="tel" id="phone" placeholder="2567XXXXXXXX" required />
                        </div>
                        <div class="form-group">
                            <label for="planSelect">Select Plan *</label>
                            <select id="planSelect" required>
                                <option value="">-- Choose a plan --</option>
                                <option value="basic">Basic – 1,000 UGX/month</option>
                                <option value="premium">Premium – 2,000 UGX/month</option>
                                <option value="enterprise">Enterprise – 3,000 UGX/year</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="currency">Currency *</label>
                            <select id="currency" required>
                                <option value="UGX">🇺🇬 UGX (Mobile Money)</option>
                                <option value="USD">🇺🇸 USD (Card / PayPal)</option>
                            </select>
                        </div>
                        <div class="form-group full-width">
                            <label for="notes">Additional Notes (optional)</label>
                            <textarea id="notes" placeholder="Any special requests?"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="submit-btn">Start Free Trial &amp; Pay</button>
                    <div id="signupError" class="error-msg"></div>
                    <div id="signupSuccess" class="success-msg"></div>
                    <div class="form-footer">
                        By subscribing you agree to our <a href="#" style="color:#00d2ff;">Terms of Service</a>.
                    </div>
                </form>
            </div>
        </div>

        <!-- LOGIN TAB -->
        <div id="login-tab" class="tab-content">
            <div class="form-section" style="max-width:500px; margin:0 auto;">
                <h2>🔐 Log In</h2>
                <form id="loginForm">
                    <div class="form-group">
                        <label for="loginEmail">Email Address</label>
                        <input type="email" id="loginEmail" required />
                    </div>
                    <div class="form-group">
                        <label for="loginPassword">Password</label>
                        <input type="password" id="loginPassword" required />
                    </div>
                    <button type="submit" class="submit-btn">Log In</button>
                    <div id="loginError" class="error-msg"></div>
                    <div id="loginSuccess" class="success-msg"></div>
                    <div class="form-footer">
                        Don’t have an account? <a href="#" onclick="switchTab('signup-tab')">Sign up now</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- PAYMENT OPTIONS -->
    <div class="payment-options">
        <div class="option">
            <h4>📱 Mobile Money</h4>
            <p>MTN / Airtel (UGX):<br /><strong>+256 7XX XXX XXX</strong><br /><small>We’ll confirm via phone.</small></p>
        </div>
        <div class="option">
            <h4>💳 Credit / Debit Cards</h4>
            <p>Pay securely via <strong>PesaPal</strong><br /><small>Visa, Mastercard, Amex</small></p>
        </div>
    </div>

    <!-- DEMO MODALS (same as before) -->
    <div id="demoModal" class="modal-overlay">
        <div class="modal" id="modalContent">
            <span class="close-btn" onclick="closeDemo()">&times;</span>
            <h2 id="modalTitle">Demo – <span id="planName">Basic</span></h2>
            <div id="modalFeatures" style="margin:10px 0;"></div>
            <div class="demo-stats" id="demoStats"></div>
            <ul class="demo-signals" id="demoSignals"></ul>
            <div style="text-align:center;">
                <button class="btn-select" onclick="closeDemo(); document.getElementById('planSelect').value = document.getElementById('planName').innerText.toLowerCase(); switchTab('signup-tab'); document.getElementById('subscribe-section').scrollIntoView({behavior:'smooth'});">
                    Select This Plan &amp; Start Free Trial
                </button>
            </div>
        </div>
    </div>

    <footer>
        &copy; 2026 Watemhost – All rights reserved.<br />
        <small>Powered by PesaPal &bull; Secure payments</small>
    </footer>
</div>

<script>
    // ============================================================
    //  DEMO DATA & FUNCTIONS (unchanged)
    // ============================================================
    const demoData = {
        basic: {
            name: 'Basic',
            features: ['Daily trading signals', 'Basic portfolio tracking', 'Email alerts', 'Web3 balance checks'],
            stats: { total: 12, buy: 7, sell: 3, hold: 2 },
            signals: [
                { pair: 'BTC/USDT', price: 67450, change: 2.1 },
                { pair: 'ETH/USDT', price: 3450, change: 1.3 },
                { pair: 'BNB/USDT', price: 560, change: -0.8 }
            ]
        },
        premium: {
            name: 'Premium',
            features: ['Real-time signals', 'Advanced portfolio tracking', 'Telegram / Discord alerts', 'Priority support', 'Custom strategies'],
            stats: { total: 28, buy: 14, sell: 8, hold: 6 },
            signals: [
                { pair: 'BTC/USDT', price: 67450, change: 2.1 },
                { pair: 'ETH/USDT', price: 3450, change: 1.3 },
                { pair: 'SOL/USDT', price: 155, change: 5.4 },
                { pair: 'XRP/USDT', price: 0.64, change: 0.9 }
            ]
        },
        enterprise: {
            name: 'Enterprise',
            features: ['Everything in Premium', 'White‑label', 'Dedicated API', '24/7 phone support', 'Team accounts (up to 5)', 'Custom integrations'],
            stats: { total: 50, buy: 25, sell: 15, hold: 10 },
            signals: [
                { pair: 'BTC/USDT', price: 67450, change: 2.1 },
                { pair: 'ETH/USDT', price: 3450, change: 1.3 },
                { pair: 'SOL/USDT', price: 155, change: 5.4 },
                { pair: 'XRP/USDT', price: 0.64, change: 0.9 },
                { pair: 'ADA/USDT', price: 0.42, change: -1.2 }
            ]
        }
    };

    function openDemo(planKey) {
        const data = demoData[planKey];
        if (!data) return;
        document.getElementById('planName').innerText = data.name;

        // Features
        let featureHtml = '<ul>';
        data.features.forEach(f => featureHtml += `<li>✅ ${f}</li>`);
        featureHtml += '</ul>';
        document.getElementById('modalFeatures').innerHTML = featureHtml;

        // Stats
        document.getElementById('demoStats').innerHTML = `
            <div class="stat"><span class="label">Total</span><div class="value">${data.stats.total}</div></div>
            <div class="stat"><span class="label">BUY</span><div class="value green">${data.stats.buy}</div></div>
            <div class="stat"><span class="label">SELL</span><div class="value red">${data.stats.sell}</div></div>
            <div class="stat"><span class="label">HOLD</span><div class="value">${data.stats.hold}</div></div>
        `;

        // Signals
        let signalHtml = '';
        data.signals.forEach(s => {
            const cls = s.change >= 0 ? 'green' : 'red';
            signalHtml += `<li><span>${s.pair}</span><span style="color:${s.change >=0 ? '#2ecc71' : '#e74c3c'};">${s.change > 0 ? '+' : ''}${s.change}%</span></li>`;
        });
        document.getElementById('demoSignals').innerHTML = signalHtml;

        document.getElementById('demoModal').classList.add('active');
    }

    function closeDemo() {
        document.getElementById('demoModal').classList.remove('active');
    }

    // ============================================================
    //  TAB SWITCHING
    // ============================================================
    function switchTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
        document.querySelector(`.tab-btn[data-tab="${tabId}"]`).classList.add('active');
    }

    // ============================================================
    //  SELECT PLAN from card button
    // ============================================================
    function selectPlan(plan) {
        document.getElementById('planSelect').value = plan;
        switchTab('signup-tab');
        document.getElementById('subscribe-section').scrollIntoView({ behavior: 'smooth' });
    }

    // ============================================================
    //  SIGNUP FORM HANDLER
    // ============================================================
    document.getElementById('signupForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const errorEl = document.getElementById('signupError');
        const successEl = document.getElementById('signupSuccess');
        errorEl.style.display = 'none';
        successEl.style.display = 'none';

        const firstName = document.getElementById('firstName').value.trim();
        const lastName = document.getElementById('lastName').value.trim();
        const email = document.getElementById('email').value.trim();
        const phone = document.getElementById('phone').value.trim();
        const plan = document.getElementById('planSelect').value;
        const currency = document.getElementById('currency').value;
        const notes = document.getElementById('notes').value.trim();

        // Validate
        if (!firstName || !lastName || !email || !phone || !plan || !currency) {
            errorEl.textContent = 'Please fill in all required fields.';
            errorEl.style.display = 'block';
            return;
        }

        // Generate a random password (user can change it later)
        const password = Math.random().toString(36).slice(-8) + 'A1!';

        try {
            // 1) Sign up
            const signupRes = await fetch('/api/auth/signup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    email,
                    password,
                    full_name: firstName + ' ' + lastName,
                    phone
                })
            });

            if (!signupRes.ok) {
                const err = await signupRes.json();
                errorEl.textContent = 'Signup failed: ' + (err.error || 'Unknown error');
                errorEl.style.display = 'block';
                return;
            }

            // 2) Log in automatically to establish session
            const loginRes = await fetch('/api/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',          // <-- required to save the cookie
                body: JSON.stringify({ email, password })
            });

            if (!loginRes.ok) {
                errorEl.textContent = 'Login failed after signup. Please log in manually.';
                errorEl.style.display = 'block';
                return;
            }

            // 3) Initiate payment
            const paymentRes = await fetch('/api/payment/initiate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',          // <-- sends the session cookie
                body: JSON.stringify({ plan, currency })
            });

            if (!paymentRes.ok) {
                const err = await paymentRes.json();
                errorEl.textContent = 'Payment initiation failed: ' + (err.error || 'Unknown error');
                errorEl.style.display = 'block';
                return;
            }

            const paymentData = await paymentRes.json();
            if (paymentData.redirect_url) {
                // Redirect to PesaPal
                window.location.href = paymentData.redirect_url;
            } else {
                errorEl.textContent = 'Payment initiated but no redirect URL received.';
                errorEl.style.display = 'block';
            }

        } catch (err) {
            errorEl.textContent = 'Network error: ' + err.message;
            errorEl.style.display = 'block';
        }
    });

    // ============================================================
    //  LOGIN FORM HANDLER
    // ============================================================
    document.getElementById('loginForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const errorEl = document.getElementById('loginError');
        const successEl = document.getElementById('loginSuccess');
        errorEl.style.display = 'none';
        successEl.style.display = 'none';

        const email = document.getElementById('loginEmail').value.trim();
        const password = document.getElementById('loginPassword').value.trim();

        if (!email || !password) {
            errorEl.textContent = 'Please enter both email and password.';
            errorEl.style.display = 'block';
            return;
        }

        try {
            const res = await fetch('/api/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ email, password })
            });

            if (!res.ok) {
                const err = await res.json();
                errorEl.textContent = err.error || 'Login failed.';
                errorEl.style.display = 'block';
                return;
            }

            // Login successful – redirect to dashboard
            window.location.href = '/dashboard';
        } catch (err) {
            errorEl.textContent = 'Network error: ' + err.message;
            errorEl.style.display = 'block';
        }
    });

    // ============================================================
    //  INIT – check if already logged in, redirect to dashboard
    // ============================================================
    async function checkAlreadyLoggedIn() {
        try {
            const res = await fetch('/api/auth/me', { credentials: 'include' });
            if (res.ok) {
                // Already logged in – go to dashboard
                window.location.href = '/dashboard';
            }
        } catch (e) {
            // Not logged in – stay on landing
        }
    }
    checkAlreadyLoggedIn();

    // Close modal on overlay click
    document.getElementById('demoModal').addEventListener('click', function(e) {
        if (e.target === this) closeDemo();
    });
</script>
</body>
</html>
