<!DOCTYPE html>
<html>
<head>
    <title>Watemhost Dashboard</title>
    <style>
        body { font-family: Arial; margin: 20px; }
        .card { border: 1px solid #ddd; border-radius: 8px; padding: 15px; margin: 10px 0; }
        .active { color: green; }
        .inactive { color: red; }
    </style>
</head>
<body>
    <h1>🤖 Watemhost Trading Bot – Dashboard</h1>
    <div id="subscription" class="card">Loading subscription...</div>
    <div id="signals" class="card">Loading signals...</div>
    <div id="balance" class="card">Loading portfolio...</div>

    <script>
        const USER_ID = 'wattsliftselecsys@gmail.com';
        const API_BASE = 'http://147.224.191.252:10000';

        async function fetchData(endpoint) {
            const res = await fetch(`${API_BASE}${endpoint}?user_id=${USER_ID}`);
            return res.json();
        }

        async function loadDashboard() {
            // Subscription
            const sub = await fetchData('/api/subscription/status');
            const subEl = document.getElementById('subscription');
            if (sub.subscription && sub.subscription.active) {
                subEl.innerHTML = `
                    <h2>✅ Subscription Active</h2>
                    <p>Plan: ${sub.subscription.plan_name}</p>
                    <p>Expires: ${new Date(sub.subscription.expires_at).toLocaleDateString()}</p>
                `;
                subEl.className = 'card active';
            } else {
                subEl.innerHTML = `<h2>❌ No Active Subscription</h2>`;
                subEl.className = 'card inactive';
            }

            // Signals
            const signals = await fetchData('/api/premium/signals');
            const sigEl = document.getElementById('signals');
            if (signals.signals) {
                sigEl.innerHTML = `
                    <h2>📈 Trading Signals</h2>
                    <ul>
                        ${signals.signals.map(s => `<li>${s.pair}: ${s.action} at $${s.price} (${s.confidence}% confidence)</li>`).join('')}
                    </ul>
                    <small>${signals.timestamp}</small>
                `;
            }

            // Balance (public endpoint, no user_id needed)
            const bal = await fetch(`${API_BASE}/api/balance`).then(r => r.json());
            const balEl = document.getElementById('balance');
            if (bal.exchange) {
                balEl.innerHTML = `
                    <h2>💰 Portfolio</h2>
                    <p>Total USDT: $${bal.exchange.total_usdt}</p>
                    <ul>
                        ${bal.exchange.assets.map(a => `<li>${a.asset}: ${a.balance} ($${a.value_usd})</li>`).join('')}
                    </ul>
                `;
            }
        }

        loadDashboard();
    </script>
</body>
</html>
